modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm start"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["jq"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["sh", "-c", "npm start"]

[[ports]]
localPort = 3000
externalPort = 8081

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"

[workflows]
runButton = "Start ChirpBot"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start ChirpBot"
author = 44048571
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[workflows.workflow]]
name = "Validate Cylinders"
author = 44048571
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run validate-cylinders"

[[workflows.workflow]]
name = "Test Generative AI"
author = 44048571
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "curl -X GET http://0.0.0.0:5000/api/ai/generative/metrics"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"Generative AI metrics retrieved successfully!\""

[agent]
integrations = ["javascript_database:1.0.0"]
