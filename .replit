modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm start"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["jq"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["sh", "-c", "npm start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 34231
externalPort = 3001

[[ports]]
localPort = 35775
externalPort = 3000

[[ports]]
localPort = 38745
externalPort = 4200

[[ports]]
localPort = 39983
externalPort = 3002

[[ports]]
localPort = 46683
externalPort = 3003

[env]
PORT = "5000"

[workflows]
runButton = "Start ChirpBot"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start ChirpBot"
author = 44048571
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"node.*server\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[workflows.workflow]]
name = "Validate Cylinders"
author = 44048571
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run validate-cylinders"

[agent]
