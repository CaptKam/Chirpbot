modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm start"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["jq"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["sh", "-c", "npm start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 32821
externalPort = 6800

[[ports]]
localPort = 34231
externalPort = 3001

[[ports]]
localPort = 34823
externalPort = 8008

[[ports]]
localPort = 35775
externalPort = 3000

[[ports]]
localPort = 35795
externalPort = 8080

[[ports]]
localPort = 35817
externalPort = 5000

[[ports]]
localPort = 35953
externalPort = 8099

[[ports]]
localPort = 36507
externalPort = 3002

[[ports]]
localPort = 37619
externalPort = 8000

[[ports]]
localPort = 38445
externalPort = 5173

[[ports]]
localPort = 38745
externalPort = 4200

[[ports]]
localPort = 39913
externalPort = 8081

[[ports]]
localPort = 42779
externalPort = 6000

[[ports]]
localPort = 46527
externalPort = 9000

[[ports]]
