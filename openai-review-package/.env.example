
# ChirpBot AI - Environment Configuration Template
# Copy this to .env and fill in your actual values

# ===== REQUIRED FOR BASIC OPERATION =====

# PostgreSQL Database Connection
DATABASE_URL=postgresql://username:password@host:port/database_name

# OpenAI API Key (Required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Session Security (Generate a random secure string)
SESSION_SECRET=your-super-secure-session-secret-minimum-32-characters

# ===== APPLICATION SETTINGS =====

# Environment Mode
NODE_ENV=production

# Server Port
PORT=5000

# ===== OPTIONAL INTEGRATIONS =====

# Telegram Bot (Optional - for notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Sports Data API (Optional - for enhanced game data)
SPORTSDATA_API_KEY=your-sportsdata-api-key-here

# Weather APIs (Optional - for weather analysis)
OPENWEATHER_API_KEY=your-openweather-api-key-here
ACCUWEATHER_API_KEY=your-accuweather-api-key-here

# ===== NOTES FOR REVIEWERS =====
# 1. Only DATABASE_URL, OPENAI_API_KEY, and SESSION_SECRET are required
# 2. The app will create demo user (username: demo, password: demo123)
# 3. Database schema is auto-created on startup
# 4. Health endpoints available at /healthz and /readyz
